import numpy as np
import matplotlib.pyplot as plt
from sklearn.decomposition import PCA
from sklearn.preprocessing import StandardScaler

# --- [User Input Section] ---
print("--- PCA with Scikit-Learn ---")
data_list = []
print("Enter your data points (e.g., '10.5, 20.2, 1.0'). Type 'done' to finish.")

while True:
    row_input = input("Row: ").lower()
    if row_input == 'done': break
    try:
        data_list.append([float(i) for i in row_input.split(',')])
    except ValueError:
        print("Invalid format. Use numbers separated by commas.")

X = np.array(data_list)

if X.shape[0] < 2 or X.shape[1] < 2:
    print("Error: PCA requires at least 2 rows and 2 columns of data.")
else:
    # 1. Scaling the Data (Highly recommended for PCA)
    # This ensures features with large scales don't dominate the components
    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    # 2. Initialize and Fit PCA
    n_input = int(input(f"Reduce to how many dimensions? (Max {min(X.shape)}): "))
    pca = PCA(n_components=n_input)
    X_reduced = pca.fit_transform(X_scaled)

    # 3. Results and Metrics
    print("\n" + "="*35)
    print("PCA RESULTS (Scikit-Learn)")
    print(f"Original Shape: {X.shape}")
    print(f"Reduced Shape:  {X_reduced.shape}")
    
    # Variance Ratio: How much 'information' is in each new axis
    var_ratio = pca.explained_variance_ratio_
    print(f"Total Variance Retained: {np.sum(var_ratio)*100:.2f}%")
    for i, v in enumerate(var_ratio):
        print(f"  - Component {i+1}: {v*100:.2f}%")
    print("="*35)

    # 4. Visualization (if 2D)
    if n_input == 2:
        plt.figure(figsize=(8, 6))
        plt.scatter(X_reduced[:, 0], X_reduced[:, 1], c='royalblue', edgecolors='k', alpha=0.8)
        plt.title("2D PCA Projection")
        plt.xlabel(f"PC1 ({var_ratio[0]*100:.1f}%)")
        plt.ylabel(f"PC2 ({var_ratio[1]*100:.1f}%)")
        plt.grid(True, linestyle='--', alpha=0.5)
        plt.show()
    else:
        print("\nReduced Matrix Data:")
        print(X_reduced)